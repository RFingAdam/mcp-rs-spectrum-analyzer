# Rohde & Schwarz Spectrum Analyzer MCP Server Configuration
# Copy this file to .env and adjust values for your setup

# =============================================================================
# Connection Settings
# =============================================================================

# Default spectrum analyzer host IP address
# Use the instrument's LAN IP address
SA_DEFAULT_HOST=192.168.1.100

# Default TCP port for SCPI socket server
# R&S spectrum analyzers use port 5025
SA_DEFAULT_PORT=5025

# TCP connection timeout in seconds
SA_CONNECTION_TIMEOUT=5.0

# SCPI command timeout in seconds
# Increase for long sweep times or high averaging counts
SA_COMMAND_TIMEOUT=30.0

# =============================================================================
# Safety Limits
# =============================================================================
# These limits protect your equipment from accidental misconfiguration.

# Maximum input power in dBm (instrument damage threshold)
# WARNING: Exceeding this WILL damage the spectrum analyzer input!
# FSW: +30 dBm, FSVA3000: +30 dBm, FSV3000: +30 dBm, FPL1000: +30 dBm
SA_MAX_INPUT_POWER_DBM=30

# Maximum frequency in Hz (90 GHz for FSW)
SA_MAX_FREQUENCY_HZ=90000000000

# Minimum frequency in Hz
SA_MIN_FREQUENCY_HZ=2

# Maximum attenuation in dB
SA_MAX_ATTENUATION_DB=75

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SA_LOG_LEVEL=INFO
